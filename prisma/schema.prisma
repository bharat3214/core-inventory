generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & Users ───────────────────────────────────────

enum UserRole {
  MANAGER
  STAFF
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  passwordHash   String
  role           UserRole  @default(STAFF)
  avatarUrl      String?
  resetToken     String?
  resetTokenExp  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  operations     Operation[]   @relation("CreatedBy")
  moveHistories  MoveHistory[] @relation("PerformedBy")
}

// ─── Products ───────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  products Product[]
}

model Product {
  id            String   @id @default(cuid())
  name          String
  sku           String   @unique
  categoryId    String?
  unitOfMeasure String   @default("Units")
  reorderLevel  Int      @default(10)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category       Category?       @relation(fields: [categoryId], references: [id])
  stockLevels    StockLevel[]
  operationItems OperationItem[]
  moveHistories  MoveHistory[]
}

// ─── Warehouses & Locations ─────────────────────────────

model Warehouse {
  id        String   @id @default(cuid())
  name      String   @unique
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  locations Location[]
}

model Location {
  id          String   @id @default(cuid())
  name        String
  warehouseId String
  description String?
  createdAt   DateTime @default(now())

  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  stockLevels     StockLevel[]
  sourceOps       Operation[]   @relation("SourceLocation")
  destOps         Operation[]   @relation("DestLocation")
  moveFromHistory MoveHistory[] @relation("MoveFrom")
  moveToHistory   MoveHistory[] @relation("MoveTo")

  @@unique([name, warehouseId])
}

// ─── Stock ──────────────────────────────────────────────

model StockLevel {
  id         String @id @default(cuid())
  productId  String
  locationId String
  quantity   Int    @default(0)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId])
}

// ─── Operations ─────────────────────────────────────────

enum OperationType {
  RECEIPT
  DELIVERY
  INTERNAL
  ADJUSTMENT
}

enum OperationStatus {
  DRAFT
  WAITING
  READY
  DONE
  CANCELLED
}

model Operation {
  id               String          @id @default(cuid())
  type             OperationType
  reference        String          @unique
  status           OperationStatus @default(DRAFT)
  sourceLocationId String?
  destLocationId   String?
  contactName      String?
  scheduledDate    DateTime?
  validatedAt      DateTime?
  notes            String?
  createdById      String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  sourceLocation Location?       @relation("SourceLocation", fields: [sourceLocationId], references: [id])
  destLocation   Location?       @relation("DestLocation", fields: [destLocationId], references: [id])
  createdBy      User            @relation("CreatedBy", fields: [createdById], references: [id])
  items          OperationItem[]
  moveHistories  MoveHistory[]
}

model OperationItem {
  id          String @id @default(cuid())
  operationId String
  productId   String
  demandQty   Int    @default(0)
  doneQty     Int    @default(0)

  operation Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])
}

// ─── Move History (Audit Trail) ─────────────────────────

enum MoveDirection {
  IN
  OUT
}

model MoveHistory {
  id             String        @id @default(cuid())
  operationId    String
  productId      String
  fromLocationId String?
  toLocationId   String?
  quantity       Int
  direction      MoveDirection
  performedById  String
  createdAt      DateTime      @default(now())

  operation    Operation @relation(fields: [operationId], references: [id])
  product      Product   @relation(fields: [productId], references: [id])
  fromLocation Location? @relation("MoveFrom", fields: [fromLocationId], references: [id])
  toLocation   Location? @relation("MoveTo", fields: [toLocationId], references: [id])
  performedBy  User      @relation("PerformedBy", fields: [performedById], references: [id])
}
